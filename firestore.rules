rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isEmailOwner(email) {
      return isAuthenticated() && 
             'email' in request.auth.token && 
             (request.auth.token.email.lower() == email.lower() || request.auth.token.email == "arqmarcilio@gmail.com");
    }

    // Allowed users collection
    match /allowed_users/{email} {
      allow read: if isEmailOwner(email);
      
      // Allow create if authenticated owner, using a valid, active and unused/reusable invite code
      allow create: if isAuthenticated() && 
                    isEmailOwner(email) &&
                    request.resource.data.active == true &&
                    request.resource.data.inviteCode != null &&
                    request.resource.data.source == "invite_code" &&
                    request.resource.data.email.lower() == request.auth.token.email.lower() &&
                    request.resource.data.uid == request.auth.uid &&
                    request.resource.data.createdAt == request.time &&
                    get(/databases/$(database)/documents/access_codes/$(request.resource.data.inviteCode)).data.active == true &&
                    (get(/databases/$(database)/documents/access_codes/$(request.resource.data.inviteCode)).data.expiresAt == null || 
                     get(/databases/$(database)/documents/access_codes/$(request.resource.data.inviteCode)).data.expiresAt > request.time) &&
                    (
                      // Caso single_use (ou tipo nao definido/nulo)
                      ((!('type' in get(/databases/$(database)/documents/access_codes/$(request.resource.data.inviteCode)).data) || 
                        get(/databases/$(database)/documents/access_codes/$(request.resource.data.inviteCode)).data.type != "test_reusable") &&
                       get(/databases/$(database)/documents/access_codes/$(request.resource.data.inviteCode)).data.used == false) ||
                      // Caso test_reusable
                      (get(/databases/$(database)/documents/access_codes/$(request.resource.data.inviteCode)).data.type == "test_reusable")
                    );
      
      // Only admin can update or delete
      allow update, delete: if isAuthenticated() && request.auth.token.email == "arqmarcilio@gmail.com";
    }

    // Access codes collection
    match /access_codes/{code} {
      allow list: if isAuthenticated() && request.auth.token.email == "arqmarcilio@gmail.com";
      allow get: if isAuthenticated();
      
      // Allow update if marking it as used by the authenticated user (only for single_use, test_reusable is read-only)
      allow update: if isAuthenticated() &&
                    (!('type' in resource.data) || resource.data.type != "test_reusable") &&
                    resource.data.used == false &&
                    request.resource.data.used == true &&
                    request.resource.data.usedByEmail.lower() == request.auth.token.email.lower() &&
                    request.resource.data.usedByUid == request.auth.uid &&
                    request.resource.data.usedAt == request.time &&
                    request.resource.data.active == resource.data.active &&
                    request.resource.data.plan == resource.data.plan &&
                    request.resource.data.createdAt == resource.data.createdAt &&
                    request.resource.data.expiresAt == resource.data.expiresAt;
                    
      allow create, delete: if isAuthenticated() && request.auth.token.email == "arqmarcilio@gmail.com";
    }

    // Recipes collection
    match /recipes/{recipeId} {
      allow read: if true;
      allow write: if isAuthenticated() && 
                          (request.resource == null || request.resource.data.userId == request.auth.uid) &&
                          (resource == null || resource.data.userId == request.auth.uid);
    }

    // Public Recipes collection
    match /public_recipes/{recipeId} {
      allow read: if true;
      allow create: if isAuthenticated();
      allow update, delete: if isAuthenticated() && 
                             (request.auth.token.email == "arqmarcilio@gmail.com" || (resource != null && resource.data.authorId == request.auth.uid));
    }
  }
}
