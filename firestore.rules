
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isEmailOwner(email) {
      return isAuthenticated() && 
             'email' in request.auth.token && 
             (request.auth.token.email.lower() == email.lower() || request.auth.token.email == "arqmarcilio@gmail.com");
    }

    function isEmailArrayUpdated() {
      let prev = 'usedByEmails' in resource.data ? resource.data.usedByEmails : [];
      let next = 'usedByEmails' in request.resource.data ? request.resource.data.usedByEmails : [];
      let email = request.auth.token.email.lower();
      return next.hasAll(prev) && next.size() == prev.size() + 1 && (email in next);
    }

    function isUidArrayUpdated() {
      let prev = 'usedByUids' in resource.data ? resource.data.usedByUids : [];
      let next = 'usedByUids' in request.resource.data ? request.resource.data.usedByUids : [];
      let uid = request.auth.uid;
      return next.hasAll(prev) && next.size() == prev.size() + 1 && (uid in next);
    }

    // Allowed users collection
    match /allowed_users/{email} {
      allow read: if isEmailOwner(email);
      
      // Allow create if authenticated owner, using a valid, active and unused invite code (supports single_use and multi_use)
      allow create: if isAuthenticated() && 
                    isEmailOwner(email) &&
                    request.resource.data.active == true &&
                    request.resource.data.inviteCode != null &&
                    request.resource.data.source == "invite_code" &&
                    request.resource.data.email.lower() == request.auth.token.email.lower() &&
                    request.resource.data.uid == request.auth.uid &&
                    request.resource.data.createdAt == request.time &&
                    get(/databases/$(database)/documents/access_codes/$(request.resource.data.inviteCode)).data.active == true &&
                    (get(/databases/$(database)/documents/access_codes/$(request.resource.data.inviteCode)).data.expiresAt == null || 
                     get(/databases/$(database)/documents/access_codes/$(request.resource.data.inviteCode)).data.expiresAt > request.time) &&
                    (
                      // Caso single_use (ou tipo nao definido/nulo)
                      ((!('type' in get(/databases/$(database)/documents/access_codes/$(request.resource.data.inviteCode)).data) || 
                        get(/databases/$(database)/documents/access_codes/$(request.resource.data.inviteCode)).data.type != "multi_use") &&
                       get(/databases/$(database)/documents/access_codes/$(request.resource.data.inviteCode)).data.used == false) ||
                      // Caso multi_use
                      (get(/databases/$(database)/documents/access_codes/$(request.resource.data.inviteCode)).data.type == "multi_use" &&
                       get(/databases/$(database)/documents/access_codes/$(request.resource.data.inviteCode)).data.used == false &&
                       (!('usedCount' in get(/databases/$(database)/documents/access_codes/$(request.resource.data.inviteCode)).data) || 
                        get(/databases/$(database)/documents/access_codes/$(request.resource.data.inviteCode)).data.usedCount < get(/databases/$(database)/documents/access_codes/$(request.resource.data.inviteCode)).data.maxUses) &&
                       (!('usedByEmails' in get(/databases/$(database)/documents/access_codes/$(request.resource.data.inviteCode)).data) || 
                        !(email.lower() in get(/databases/$(database)/documents/access_codes/$(request.resource.data.inviteCode)).data.usedByEmails)) &&
                       (!('usedByUids' in get(/databases/$(database)/documents/access_codes/$(request.resource.data.inviteCode)).data) || 
                        !(request.auth.uid in get(/databases/$(database)/documents/access_codes/$(request.resource.data.inviteCode)).data.usedByUids)))
                    );
      
      // Only admin can update or delete
      allow update, delete: if isAuthenticated() && request.auth.token.email == "arqmarcilio@gmail.com";
    }

    // Access codes collection
    match /access_codes/{code} {
      allow list: if isAuthenticated() && request.auth.token.email == "arqmarcilio@gmail.com";
      allow get: if isAuthenticated();
      
      // Allow update if marking it as used by the authenticated user (supports single_use and multi_use)
      allow update: if isAuthenticated() &&
                    resource.data.used == false &&
                    (
                      // Caso single_use
                      ((!('type' in resource.data) || resource.data.type != "multi_use") &&
                       request.resource.data.used == true &&
                       request.resource.data.usedByEmail.lower() == request.auth.token.email.lower() &&
                       request.resource.data.usedByUid == request.auth.uid &&
                       request.resource.data.usedAt == request.time &&
                       request.resource.data.active == resource.data.active &&
                       request.resource.data.plan == resource.data.plan &&
                       request.resource.data.createdAt == resource.data.createdAt &&
                       request.resource.data.expiresAt == resource.data.expiresAt) ||
                      // Caso multi_use
                      (resource.data.type == "multi_use" &&
                       (!('usedByEmails' in resource.data) || !(request.auth.token.email.lower() in resource.data.usedByEmails)) &&
                       (!('usedByUids' in resource.data) || !(request.auth.uid in resource.data.usedByUids)) &&
                       isEmailArrayUpdated() &&
                       isUidArrayUpdated() &&
                       request.resource.data.usedCount == resource.data.usedCount + 1 &&
                       request.resource.data.lastUsedAt == request.time &&
                       (request.resource.data.usedCount >= resource.data.maxUses ? request.resource.data.used == true : request.resource.data.used == false) &&
                       request.resource.data.active == resource.data.active &&
                       request.resource.data.plan == resource.data.plan &&
                       request.resource.data.createdAt == resource.data.createdAt &&
                       request.resource.data.expiresAt == resource.data.expiresAt &&
                       request.resource.data.maxUses == resource.data.maxUses &&
                       request.resource.data.type == resource.data.type
                      )
                    );
                    
      allow create, delete: if isAuthenticated() && request.auth.token.email == "arqmarcilio@gmail.com";
    }

    // Recipes collection
    match /recipes/{recipeId} {
      allow read: if true;
      allow write: if isAuthenticated() && 
                          (request.resource == null || request.resource.data.userId == request.auth.uid) &&
                          (resource == null || resource.data.userId == request.auth.uid);
    }

    // Public Recipes collection
    match /public_recipes/{recipeId} {
      allow read: if true;
      allow create: if isAuthenticated();
      allow update, delete: if isAuthenticated() && 
                             (request.auth.token.email == "arqmarcilio@gmail.com" || (resource != null && resource.data.authorId == request.auth.uid));
    }
  }
}
