
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isEmailOwner(email) {
      return isAuthenticated() && 
             'email' in request.auth.token && 
             (request.auth.token.email.lower() == email.lower() || request.auth.token.email == "arqmarcilio@gmail.com");
    }

    // Allowed users collection
    match /allowed_users/{email} {
      // Users can read their own authorization status
      allow read: if isEmailOwner(email);
      
      // Only admins can create or update allowed users
      // For now, we'll allow the first admin (the user who set up the app)
      allow write: if isAuthenticated() && request.auth.token.email == "arqmarcilio@gmail.com";
    }

    // Recipes collection
    match /recipes/{recipeId} {
      // Allow public read for previews (WhatsApp, etc.)
      allow read: if true;
      
      // Only authenticated owners can write or delete
      allow write: if isAuthenticated() && 
                          (request.resource == null || request.resource.data.userId == request.auth.uid) &&
                          (resource == null || resource.data.userId == request.auth.uid);
    }

    // Public Recipes collection
    match /public_recipes/{recipeId} {
      // Allow public read for everyone
      allow read: if true;
      
      // Only authenticated users can create
      allow create: if isAuthenticated();
      
      // Only admins or authors can update/delete
      allow update, delete: if isAuthenticated() && 
                             (request.auth.token.email == "arqmarcilio@gmail.com" || (resource != null && resource.data.authorId == request.auth.uid));
    }
  }
}
