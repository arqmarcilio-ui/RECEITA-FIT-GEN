# Gemini API Key (Frontend/Backend)
GEMINI_API_KEY=

# OpenAI API Key (Backend only)
OPENAI_API_KEY=

# Firebase Service Account (Backend only)
# Format: JSON string of the service account key file
FIREBASE_SERVICE_ACCOUNT=

# Firebase Storage Bucket (Backend only)
# Format: project-id.appspot.com
FIREBASE_STORAGE_BUCKET=
