
{
  "entities": {
    "AllowedUser": {
      "title": "Allowed User",
      "description": "A user authorized to access the application.",
      "type": "object",
      "properties": {
        "active": {
          "type": "boolean",
          "description": "Whether the user is currently authorized."
        }
      },
      "required": ["active"]
    },
    "Recipe": {
      "title": "Recipe",
      "description": "A generated healthy recipe.",
      "type": "object",
      "properties": {
        "userId": { "type": "string", "description": "The UID of the user who generated the recipe." },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "ingredients": { "type": "array", "items": { "type": "string" } },
        "instructions": { "type": "array", "items": { "type": "string" } },
        "imageUrl": { "type": "string" },
        "estimatedCost": { "type": "string" },
        "estimatedTime": { "type": "string" },
        "macros": {
          "type": "object",
          "properties": {
            "protein": { "type": "string" },
            "carbs": { "type": "string" },
            "fats": { "type": "string" },
            "calories": { "type": "string" }
          }
        },
        "createdAt": { "type": "string", "format": "date-time" },
        "isFavorite": { "type": "boolean" }
      },
      "required": ["userId", "title", "createdAt"]
    }
  },
  "firestore": {
    "/allowed_users/{email}": {
      "schema": "AllowedUser",
      "description": "Collection of authorized users, indexed by email."
    },
    "/recipes/{recipeId}": {
      "schema": "Recipe",
      "description": "Collection of generated recipes."
    },
    "/public_recipes/{recipeId}": {
      "schema": "Recipe",
      "description": "Collection of recipes generated by all users."
    }
  }
}
